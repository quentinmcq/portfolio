{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "portfolio",
  "main": "worker/index.ts",
  "compatibility_date": "2026-05-25",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  },
  "send_email": [
    {
      "name": "SEND_EMAIL",
      "destination_address": "quentin.macq@outlook.fr"
    }
  ],
  "observability": {
    "enabled": true
  }
}
