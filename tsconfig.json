{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "vite.config.*",
    "env.d.ts",
    "src/**/*",
    "worker/**/*"
  ],
  "compilerOptions": {
    "noUnusedLocals": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": [
      "node",
      "vite/client",
      "@cloudflare/workers-types"
    ]
  }
}
