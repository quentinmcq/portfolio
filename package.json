{
  "name": "portfolio",
  "version": "3.0.0",
  "private": true,
  "author": "Quentin Macq",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build && vp build --ssr src/entry-server.ts --outDir dist-server && bun scripts/prerender.mjs",
    "preview": "vp preview",
    "deploy": "wrangler deploy",
    "fmt": "vp check --fix",
    "lint": "vp lint --fix"
  },
  "dependencies": {
    "typescript": "^6.0.3",
    "vue": "^3.6.0-beta.17",
    "vue-i18n": "^11.4.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260707.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "sass-embedded": "^1.100.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "wrangler": "^4.107.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "browserslist": [
    "last 2 chrome versions",
    "last 2 firefox versions",
    "last 2 safari versions",
    "last 2 edge versions",
    "not dead"
  ],
  "packageManager": "bun@1.3.14"
}
